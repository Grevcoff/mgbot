# Пример файла переменных окружения
# Скопируйте этот файл в .env и заполните реальные значения

# Токен Telegram бота (получить у @BotFather)
BOT_TOKEN=123456789:AAH-example_token_here

# ID администратора бота
ADMIN_ID=123456789

# Интервал проверки этапов в минутах
CHECK_INTERVAL_MIN=15

# Путь к файлу базы данных
DB_PATH=microgreen_bot.db

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Путь к файлу логов
LOG_FILE=bot.log

# Код подтверждения для сброса базы данных (измените на свой уникальный код)
RESET_CONFIRM_CODE=123456
